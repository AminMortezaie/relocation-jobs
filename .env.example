# Flask session signing (set in production)
PANEL_SECRET_KEY=change-me-to-a-long-random-string

# First-run admin account (only used when the database has no users).
# On Render: set PANEL_ADMIN_PASSWORD in the dashboard BEFORE the first deploy,
# or redeploy after setting it — startup syncs this password to the admin user.
PANEL_ADMIN_USER=admin
PANEL_ADMIN_PASSWORD=change-me

# SQLite path (default: data/panel.db locally) — ignored when DATABASE_URL is set
# PANEL_DATA_DIR=data
# PANEL_DB_PATH=data/panel.db

# Postgres (required in production). Schema via init_db() on startup.
# Migrate from Neon: scripts/aws_postgres_migrate.sh (see docs/operations/aws-postgres.md)
#
# Neon (pooler for serverless; use direct host for pg_dump):
# DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require
#
# AWS EC2 Docker (Scenario A — local scrape + Render; open 5432 for Render egress):
# DATABASE_URL=postgresql://relocation:PASSWORD@<ELASTIC_IP>:5432/relocation_jobs?sslmode=prefer
#
# AWS RDS (Scenario B):
# DATABASE_URL=postgresql://relocation:PASSWORD@your-instance.region.rds.amazonaws.com:5432/relocation_jobs?sslmode=require
#
# Local dev (fast iteration):
# DATABASE_URL=postgresql://localhost:5432/relocation_jobs

# Redis on EC2 (country registry pilot — see scripts/ec2_redis.sh):
# REDIS_URL=redis://:PASSWORD@<ELASTIC_IP>:6379/0
# When set, country labels are stored in Redis hash countries:labels (shared Render + local).
# Postgres custom_countries remains fallback when REDIS_URL is unset (tests/local).

# AWS CLI (optional — for scripts/aws_postgres_migrate.sh; gitignored via .env)
# Run sync-sg after your public IP changes (fixes SSH/Postgres lockout):
#   ./scripts/aws_postgres_migrate.sh sync-sg
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=eu-central-1

# Disable in-browser scraping (default on Render free — 512MB RAM)
# PANEL_SCRAPE_ENABLED=0

# Fetch scheduler timeouts (EC2 worker — see docs/reference/fetch-scheduler-timeout-practices.md)
# FETCH_COMPANY_TIMEOUT_SECONDS=300
# FETCH_COUNTRY_TIMEOUT_SECONDS=2700
# PLAYWRIGHT_BOARD_TIMEOUT_SECONDS=90

# Allow self-service registration after the first user exists
# PANEL_ALLOW_REGISTER=1

# Claude Desktop MCP server (scripts/mcp_server.py) — see docs/reference/mcp-application.md
# MCP_USERNAME=admin
# MCP_USER_ID=
# MCP_LATEX_CMD=tectonic
